# bkit (local tool state — never commit, per global CLAUDE.md §11)
.bkit/
# Claude Code local tool state (ScheduleWakeup locks, etc.) — never commit.
.claude/

# Gradle
.gradle/
# Ignore module build outputs, but keep source packages named build, such as
# server/src/main/kotlin/.../server/build/ApkFinder.kt.
**/build/
!**/src/**/build/
!**/src/**/build/**
!gradle/wrapper/gradle-wrapper.jar
local.properties

# IntelliJ / Android Studio
.idea/
*.iml
.kotlin/
captures/
.cxx/

# Server runtime data (workspace, db, logs)
docker/vibe-coder-data/
vibe-coder-server-data/
server/workspace/
/workspace/

# DB
*.db
*.db-journal
*.db-shm
*.db-wal

# APK / artifacts
*.apk
*.aab

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker local artifacts (private config / build context outputs)
docker/.env
docker/*.local.yml
docker/build-context/

# Operator-internal docs. Public users should only need README (v0.10.0+).
# CLAUDE.md is Claude Code memory/rules, so it stays operator-only.
# docs/ contains PDCA work artifacts (plan/design/analysis/report).
CLAUDE.md
docs/
vibe-coder-icon.png
Screenshot_*.jpg

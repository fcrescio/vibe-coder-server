# syntax=docker/dockerfile:1.7
#
# Vibe Coder Server — :full 변형 (에뮬레이터 + noVNC 포함, v0.20+ 예정)
#
# 본 파일은 v0.19.0 시점 **스캐폴드** 이다. v0.20+ 에서 본격 활성화 예정.
# 현재는 시스템 패키지 / system-image 다운로드까지만 검증되어 있고,
# `/emulator` 페이지에서 노출하는 in-browser VNC 통합은 다음 마일스톤에서
# 완성된다 (Roadmap §C ☆ "Android 에뮬레이터 실행 + 조작").
#
# 사용 시점
#   docker pull siamakerlab/vibe-coder-server:full        # ≈ 3-4 GB
#
# 슬림 (`Dockerfile`) 과 차이
#   - qemu-system-x86_64 + KVM userland (~400 MB)
#   - Xvfb + x11vnc + websockify + noVNC (~150 MB)
#   - android-35 system-image (~1.2 GB)
#   - emulator + adb 가 SDK 일부로 함께 (~200 MB)
#
# 빌드 (메인테이너용)
#
#   amd64-only (KVM 은 host arch 의존이라 cross-build 무의미):
#     docker buildx build --platform linux/amd64 \
#         -f docker/Dockerfile.full \
#         -t siamakerlab/vibe-coder-server:full \
#         -t siamakerlab/vibe-coder-server:0.20.0-full \
#         --push .
#
# 런타임 요구사항 (compose)
#   services.vibe-coder-server.devices: [/dev/kvm:/dev/kvm]
#   services.vibe-coder-server.group_add: ["${KVM_GID:-104}"]   # host kvm gid
#
# ------------------------------------------------------------------------------
# Stage 1: 서버 빌드 (Dockerfile 슬림본과 동일)
# ------------------------------------------------------------------------------
FROM eclipse-temurin:17-jdk-noble AS builder

WORKDIR /src
COPY gradle ./gradle
COPY gradlew ./gradlew
COPY settings.gradle.kts build.gradle.kts gradle.properties ./
COPY shared/build.gradle.kts ./shared/
COPY server/build.gradle.kts ./server/
COPY shared ./shared
COPY server ./server

RUN --mount=type=cache,target=/root/.gradle \
    --mount=type=cache,target=/src/.gradle \
    chmod +x ./gradlew && \
    ./gradlew -PskipAndroidModule=true :server:installDist --no-daemon -x test

# ------------------------------------------------------------------------------
# Stage 2: :full 런타임 — 슬림 + 에뮬레이터 + noVNC 스택
# ------------------------------------------------------------------------------
FROM eclipse-temurin:17-jre-noble AS runtime

LABEL org.opencontainers.image.title="Vibe Coder Server (full / emulator variant)"
LABEL org.opencontainers.image.description="Slim 이미지 + Android Emulator (KVM) + noVNC (in-browser AVD mirroring)"
LABEL org.opencontainers.image.source="https://github.com/siamakerlab/vibe-coder-server"
LABEL org.opencontainers.image.licenses="AGPL-3.0-or-later"

ENV DEBIAN_FRONTEND=noninteractive

# ---- 시스템 패키지: 슬림 셋 + qemu/KVM + X/VNC -------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        bash ca-certificates curl git gosu gnupg jq openssl sudo tini \
        tzdata unzip util-linux wget xz-utils zip \
        # KVM userland (host /dev/kvm 패스스루 필요)
        qemu-system-x86 qemu-utils libvirt-clients \
        # X server (가상) + window manager / VNC
        xvfb x11-utils x11-xserver-utils fluxbox \
        x11vnc websockify novnc \
        # 에뮬레이터 GUI/오디오 의존성
        libgl1 libpulse0 libnss3 libxcb-cursor0 libxcomposite1 libxdamage1 \
        libxrandr2 libxkbcommon0 libatk1.0-0 libatk-bridge2.0-0 libgtk-3-0 \
    && rm -rf /var/lib/apt/lists/*

# ---- Node.js 20 LTS + Claude Code CLI ----------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm config set fund false \
    && npm config set update-notifier false \
    && npm install -g @anthropic-ai/claude-code \
    && npm cache clean --force

# ---- 사용자 + 디렉토리 -------------------------------------------------------
ARG VIBE_UID=1000
ARG VIBE_GID=1000
RUN userdel -r ubuntu 2>/dev/null || true \
    && groupdel ubuntu 2>/dev/null || true \
    && groupadd --gid ${VIBE_GID} vibe \
    && useradd --uid ${VIBE_UID} --gid ${VIBE_GID} --create-home --shell /bin/bash vibe \
    && mkdir -p \
        /opt/android-sdk \
        /workspace \
        /data \
        /home/vibe/.android \
        /home/vibe/.claude \
        /home/vibe/.gradle \
        /home/vibe/.config \
        /home/vibe/.npm \
        /home/vibe/.cache \
        /home/vibe/.cache/ms-playwright \
        /home/vibe/.local/bin \
        /home/vibe/.local/lib/node_modules \
    && printf 'prefix=/home/vibe/.local\nfund=false\nupdate-notifier=false\n' > /home/vibe/.npmrc \
    && chown -R vibe:vibe /opt/android-sdk /workspace /data /home/vibe \
    && printf 'vibe ALL=(ALL) NOPASSWD: ALL\n' > /etc/sudoers.d/vibe-nopasswd \
    && chmod 0440 /etc/sudoers.d/vibe-nopasswd \
    && visudo -c -f /etc/sudoers.d/vibe-nopasswd

# ---- vibe-coder 서버 본체 ---------------------------------------------------
COPY --from=builder --chown=vibe:vibe /src/server/build/install/server /opt/vibe-coder

# ---- doctor / entrypoint -----------------------------------------------------
COPY --chown=root:root docker/doctor /opt/vibe-doctor
COPY --chown=root:root docker/entrypoint.sh /usr/local/bin/entrypoint.sh
# v0.20+ 에서 추가될 emulator-entrypoint.sh — Xvfb + x11vnc + websockify 부트.
# 슬림 이미지의 entrypoint 를 그대로 쓰되, /emulator 페이지가 별도 SSE / WS 로
# AVD 부트 신호를 보내면 사이드 데몬으로 띄우는 패턴 (TODO).
RUN chmod +x /opt/vibe-doctor/vibe-doctor \
    && chmod +x /opt/vibe-doctor/lib/*.sh \
    && chmod +x /usr/local/bin/entrypoint.sh \
    && ln -s /opt/vibe-doctor/vibe-doctor /usr/local/bin/vibe-doctor \
    && ln -s /opt/vibe-coder/bin/server /usr/local/bin/vibe-coder-server

# ---- 환경변수 ----------------------------------------------------------------
ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_SDK_ROOT=/opt/android-sdk
ENV PATH=/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:/opt/android-sdk/emulator:${PATH}
ENV VIBECODER_WORKSPACE_ROOT=/workspace
ENV VIBECODER_DATA_DIR=/data
ENV CLAUDE_CONFIG_DIR=/home/vibe/.claude
ENV PATH=/home/vibe/.local/bin:${PATH}

# Xvfb 가상 디스플레이 (v0.20+ entrypoint 에서 활용)
ENV DISPLAY=:99
ENV XAUTHORITY=/home/vibe/.Xauthority
# noVNC 정적 자원 위치 — admin SSR 의 /emulator/vnc/ 가 reverse-proxy 로 가린다
ENV NOVNC_ROOT=/usr/share/novnc
ENV WEBSOCKIFY_PORT=6080
ENV VNC_PORT=5900

ENV JAVA_OPTS="-Xmx2g -XX:+UseG1GC -Dfile.encoding=UTF-8"

# ---- 포트 / 헬스체크 ---------------------------------------------------------
EXPOSE 17880
# 5900 (VNC) / 6080 (websockify) 는 컨테이너 내부에서만 사용 — admin SSR 가
# /emulator/vnc/ 로 proxy 해서 인증 boundary 안으로 끌고 들어옴.

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -fsS http://127.0.0.1:17880/health || exit 1

# ---- 실행 -------------------------------------------------------------------
WORKDIR /workspace
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
CMD ["server"]

# ==============================================================================
# v0.20+ TODO (이 스캐폴드를 끝내기 전 마저 해야 할 일)
# ==============================================================================
# 1. emulator-entrypoint.sh 작성
#    - Xvfb :99 -screen 0 1080x1920x24 백그라운드 부트
#    - fluxbox & — minimal WM
#    - x11vnc -display :99 -nopw -listen 127.0.0.1 -xkb &
#    - websockify --web=$NOVNC_ROOT $WEBSOCKIFY_PORT 127.0.0.1:$VNC_PORT &
#    - 그 후 /usr/local/bin/entrypoint.sh server 호출
# 2. SDK 사전 설치 (이미지에 박는 안 vs 첫 부팅 시 doctor 가 잡는 안)
#    - system-image (~1.2 GB) 는 캐시 효율 위해 이미지 레이어로 들이는 게 빠름
#    - 단 사용자 API level 선택권을 주려면 doctor 경유가 유연
# 3. AVD 기본 프로파일 자동 생성 (vibe-doctor avd-default)
# 4. EmulatorService 확장: launch / stop / wipe API 노출
# 5. admin SSR /emulator/vnc/ proxy 라우트 (kotlinx-coroutines + websockify)
# 6. compose.yml 에 :full 변형 옵션 documenting + group_add KVM_GID 가이드

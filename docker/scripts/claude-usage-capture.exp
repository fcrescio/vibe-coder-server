#!/usr/bin/expect -f
# v1.5.1 — Claude Code 2.1.x TUI 의 Usage 탭 PTY capture.
#
# 배경: Claude Code 2.1.x 부터 모든 slash command 가 --print 모드에서 차단됨
# ("/status isn't available in this environment."). quota 정보는 interactive
# TUI 의 Usage 탭에서만 확인 가능. 본 expect 스크립트는 PTY 안에서 Claude 를
# spawn → /status 입력 → 5탭 TUI 의 Settings 탭 첫 화면 → → → 3번 화살표로
# Usage 탭 이동 → w/d 키 redraw → 화면 capture → Esc + Ctrl-D 로 종료.
#
# v1.5.1 — trust dialog 강제 통과 코드 제거. 이전 v1.4.2 의 send "2\r" 가
# 이미 bypass-on 상태인 prompt 에 "2" user message 로 들어가 prompt 망가뜨림.
# 이미지에 prebuilt 된 ~/.claude/.claude.json 의 trust 기록 + entrypoint 의
# /home/vibe 영속 볼륨 (`.claude`) 으로 매번 첫 부팅 confirmation 없이 진입.
#
# 매우 fragile — Claude CLI UI 가 변경되면 즉시 깨짐.
#
# 사용법: claude-usage-capture.exp <cwd>
#   cwd: claude 가 spawn 될 디렉토리 (보통 SCRATCH_PROJECT 의 /workspace/__scratch__)
# 출력: stdout 으로 Usage 탭의 raw screen content. ANSI escape + box-drawing 포함.
#       server-side stripAnsiAndBoxChars + parseUsageOutput 이 정리.
# 종료 코드: 성공 0, spawn 실패 1.

set timeout 60
set cwd [lindex $argv 0]
if {$cwd eq ""} { set cwd "/workspace/__scratch__" }

# log_user 1 — 전체 raw 를 stdout 으로. server-side 가 ANSI/box-drawing 정리 후 parsing.
log_user 1

# 디렉토리 이동 — claude 가 cwd 영향 받음 (.claude/settings.json 검색 등).
if {[catch {cd $cwd} err]} {
    puts stderr "expect: cd $cwd failed: $err"
    exit 1
}

# Claude TUI spawn.
spawn -noecho claude --dangerously-skip-permissions

# init render 완료 대기 (prompt-ready).
sleep 4

# /status 입력 — 5탭 TUI dialog (Settings 탭 시작).
send "/status\r"
sleep 3

# → 화살표 3번 (Settings → Status → Config → Usage)
send "\x1b\[C"; sleep 0.5
send "\x1b\[C"; sleep 0.5
send "\x1b\[C"; sleep 2

# w/d 키로 화면 redraw 유도 (Current week / Current day 토글) — capture 완성도 향상.
send "w"; sleep 1.5
send "d"; sleep 1.5
send "w"; sleep 1.5

# 정리: dialog 닫기 + Claude 종료.
send "\x1b"      ;# Esc
sleep 0.5
send "\x04"      ;# Ctrl-D
expect {
    eof {}
    timeout { catch {close} }
}
exit 0
